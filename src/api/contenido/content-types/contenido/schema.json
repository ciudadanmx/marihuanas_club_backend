{
  "kind": "collectionType",
  "collectionName": "contenidos",
  "info": {
    "singularName": "contenido",
    "pluralName": "contenidos",
    "displayName": "Contenidos"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titulo": {
      "type": "string"
    },
    "slug": {
      "type": "uid"
    },
    "autor": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "contenido_libre": {
      "type": "json"
    },
    "contenido_restringido": {
      "type": "json"
    },
    "restringido": {
      "type": "boolean"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "borrador",
        "publicado",
        "archivado"
      ]
    },
    "portada": {
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ],
      "type": "media",
      "multiple": false
    },
    "galeria_libre": {
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ],
      "type": "media",
      "multiple": true
    },
    "galeria_restringida": {
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ],
      "type": "media",
      "multiple": true
    },
    "tags": {
      "type": "text"
    },
    "fecha_publicacion": {
      "type": "datetime"
    },
    "resumen": {
      "type": "string"
    }
  }
}
